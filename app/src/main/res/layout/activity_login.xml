<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLogin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginActivity">

    <TextView
        android:id="@+id/textTitoloLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Accedi"
        android:textSize="34sp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="154dp"
        tools:layout_editor_absoluteY="60dp" />

    <TextView
        android:id="@+id/textErroreLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="I dati non sono corretti"
        android:textColor="#FF2C2C"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:layout_editor_absoluteX="125dp"
        tools:layout_editor_absoluteY="138dp"
        tools:visibility="visible" />

    <EditText
        android:id="@+id/editUsername"
        android:layout_width="280dp"
        android:layout_height="55dp"
        android:background="#EFEFEF"
        android:hint="Email, Telefono o Username"
        android:inputType="text"
        android:padding="12dp"
        tools:layout_editor_absoluteX="66dp"
        tools:layout_editor_absoluteY="167dp" />

    <EditText
        android:id="@+id/editPassword"
        android:layout_width="280dp"
        android:layout_height="55dp"
        android:background="#EFEFEF"
        android:hint="Password"
        android:inputType="textPassword"
        android:padding="12dp"
        tools:layout_editor_absoluteX="66dp"
        tools:layout_editor_absoluteY="238dp" />

    <Button
        android:id="@+id/btnAccedi"
        android:layout_width="280dp"
        android:layout_height="55dp"
        android:backgroundTint="#FF2C2C"
        android:text="Accedi"
        tools:layout_editor_absoluteX="66dp"
        tools:layout_editor_absoluteY="325dp" />

    <Button
        android:id="@+id/btnGoogle"
        android:layout_width="280dp"
        android:layout_height="55dp"
        android:background="@android:color/transparent"
        android:text="Entra con Google"
        android:textColor="#FF2C2C"
        tools:layout_editor_absoluteX="66dp"
        tools:layout_editor_absoluteY="396dp" />

</androidx.constraintlayout.widget.ConstraintLayout>