<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_bg"
    tools:context=".GrazieActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iconaSuccesso"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/checkbox_on_background"
            app:tint="#4CAF50" />

        <TextView
            android:id="@+id/textPagamentoEffettuato"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Pagamento effettuato!"
            android:textColor="@color/text_color_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textGrazieNome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Grazie per l'acquisto, [NOME]"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/textRicevuta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Ricevuta inviata all'indirizzo di posta elettronica"
            android:textAlignment="center"
            android:textColor="#757575"
            android:textSize="14sp" />

    </LinearLayout>

    <Button
        android:id="@+id/btnFinisci"
        android:layout_width="280dp"
        android:layout_height="55dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#FF2C2C"
        android:onClick="tornaAllaHome"
        android:text="Finisci"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
