<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="?android:attr/colorBackground"
    android:padding="24dp">

    <ImageView
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/burger"
        android:layout_marginBottom="24dp"
        android:contentDescription="Logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Identificati per continuare"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Per completare l'ordine o vedere il tuo storico, devi accedere al tuo account Totem."
        android:textSize="16sp"
        android:textColor="#6b7280"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <Button
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="ACCEDI"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        app:cornerRadius="16dp"
        android:onClick="vaiALogin" />

    <Button
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="REGISTRATI"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        app:cornerRadius="16dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:onClick="vaiARegister" />

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Annulla e Torna indietro"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textColor="#FF5252"
        android:onClick="chiudiHome" />

</LinearLayout>